root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yaml,yml,json}]
indent_size = 2

[*.{kt,kts}]
indent_size = 4

[*.rs]
indent_size = 4
max_line_length = 100

[*.xml]
indent_size = 4

[Makefile]
indent_style = tab

[*.gradle.kts]
indent_size = 4
