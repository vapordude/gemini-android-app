<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Light default — Compose drives the in-app palette. -->
    <style name="Theme.KaimahiUI" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/kaimahi_bg_light</item>
        <item name="android:statusBarColor">@color/kaimahi_bg_light</item>
        <item name="android:navigationBarColor">@color/kaimahi_bg_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>
</resources>
